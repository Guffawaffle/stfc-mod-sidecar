{
  "name": "stfc-mod-sidecar",
  "version": "0.0.1-Alpha",
  "private": true,
  "description": "Read-only diagnostic sidecar and integration bridge for STFC Community Mod events.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "check": "npm run build && npm test",
    "ax": "node ./scripts/ax.mjs",
    "ci": "node ./scripts/ax.mjs ci",
    "server:start": "node ./scripts/viewer-server-control.mjs start",
    "server:stop": "node ./scripts/viewer-server-control.mjs stop",
    "server:kill": "node ./scripts/viewer-server-control.mjs kill",
    "server:status": "node ./scripts/viewer-server-control.mjs status",
    "server:restart": "node ./scripts/viewer-server-control.mjs restart",
    "server:logs": "node ./scripts/viewer-server-control.mjs logs",
    "smoke:mod-install": "node ./scripts/community-mod-install-smoke.mjs",
    "desktop:dev": "npm run dev --workspace @stfc-mod-sidecar/desktop",
    "desktop:pack": "npm run pack --workspace @stfc-mod-sidecar/desktop",
    "desktop:dist": "npm run dist --workspace @stfc-mod-sidecar/desktop",
    "desktop:dist:win": "node ./scripts/ax.mjs dist:win",
    "analyze:attack-scalars": "node ./scripts/analyze-attack-scalars.mjs",
    "viewer": "npm run server:start",
    "viewer:run": "npm run build --workspace @stfc-mod-sidecar/core && node packages/viewer/server.mjs",
    "viewer:sample": "npm run server:start -- --feed-path ./examples/sample-battle-events.jsonl"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/pg": "^8.15.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
