{
  "name": "stfc-mod-sidecar",
  "version": "0.0.0",
  "private": true,
  "description": "Read-only diagnostic sidecar and integration bridge for STFC Community Mod events.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "check": "npm run build && npm test",
    "viewer": "npm run build --workspace @stfc-mod-sidecar/core && node packages/viewer/server.mjs",
    "viewer:sample": "npm run build --workspace @stfc-mod-sidecar/core && node packages/viewer/server.mjs --feed-path ./examples/sample-battle-events.jsonl"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
