{
  "name": "@stfc-mod-sidecar/desktop",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Desktop companion shell for STFC Mod Sidecar.",
  "author": "Joseph Gustavson",
  "type": "module",
  "main": "src/main.mjs",
  "scripts": {
    "dev": "npm run build --workspace @stfc-mod-sidecar/core && electron ./src/main.mjs",
    "pack": "npm run build --workspace @stfc-mod-sidecar/core && electron-builder --dir --config electron-builder.config.cjs",
    "dist": "npm run build --workspace @stfc-mod-sidecar/core && electron-builder --config electron-builder.config.cjs",
    "dist:win": "npm run build --workspace @stfc-mod-sidecar/core && electron-builder --win --config electron-builder.config.cjs",
    "test": "vitest run --dir test"
  },
  "devDependencies": {
    "electron": "41.5.0",
    "electron-builder": "26.8.1"
  }
}
